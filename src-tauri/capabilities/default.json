{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Main window capabilities for markdown-viewer",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:default",
    "core:webview:default",
    "cli:default",
    "dialog:default",
    "dialog:allow-open",
    "opener:default",
    "opener:allow-open-url",
    "opener:allow-open-path",
    "fs:allow-read-text-file",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$HOME/**" },
        { "path": "$DESKTOP/**" },
        { "path": "$DOCUMENT/**" },
        { "path": "$DOWNLOAD/**" },
        { "path": "$RESOURCE/**" },
        { "path": "$TEMP/**" }
      ]
    }
  ]
}
